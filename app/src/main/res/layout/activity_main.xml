<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0F1C"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:paddingHorizontal="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="4dp">

        <Button
            android:id="@+id/overflowMenuButton"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:backgroundTint="#111827"
            android:text="⋮"
            android:textColor="#E5E7EB"
            android:textSize="18sp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/chatRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingHorizontal="10dp"
        android:paddingBottom="6dp" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="12dp"
        android:paddingBottom="6dp"
        android:text="Estat: llest"
        android:textColor="#9CA3AF"
        android:textSize="12sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp">

        <EditText
            android:id="@+id/messageEdit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:background="#111827"
            android:hint="Escriu un missatge..."
            android:textColorHint="#6B7280"
            android:inputType="textMultiLine|textCapSentences"
            android:maxLines="4"
            android:padding="12dp"
            android:textColor="#F9FAFB" />

        <Button
            android:id="@+id/sendButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:backgroundTint="#EF4444"
            android:text="Send"
            android:textColor="#FFFFFF" />
    </LinearLayout>

</LinearLayout>
